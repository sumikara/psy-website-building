---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import DreamCard from '../../components/DreamCard.astro';

const posts = (await getCollection('ruyalar')).sort((a,b)=>b.data.date.valueOf()-a.data.date.valueOf());
---
<BaseLayout title="Gece Vardiyası · Sumi Lab">
  <SectionHeader title="Gece Vardiyası" subtitle="Rüyalar burada çözülmesi gereken bilmecelerden çok, bedenin ve bilinçdışının gece tuttuğu notlar gibi okunur." />
  <div class="grid cards-grid">{posts.map((post)=><DreamCard post={post} />)}</div>
</BaseLayout>
