---
import TagList from './TagList.astro';
import BookCandidateBadge from './BookCandidateBadge.astro';
interface Props { post: any }
const { post } = Astro.props;
const categoryMap: Record<string, string> = {
  beden_sinir_sistemi: 'Beden & Sinir Sistemi',
  sinirlar_iletisim: 'Sınırlar & İletişim',
  baglanma_laboratuvari: 'Bağlanma Laboratuvarı',
  kokler_golgeler: 'Kökler & Gölgeler',
  edebiyat_felsefe: 'Edebiyat & Felsefe'
};
---
<article class="card">
  <p class="meta">{post.data.date.toLocaleDateString('tr-TR')} · {categoryMap[post.data.category]}</p>
  <h3><a href={`/laboratuvar/${post.slug}`}>{post.data.title}</a></h3>
  <p>{post.data.description}</p>
  <TagList items={post.data.tags} />
  {post.data.book_candidate && <BookCandidateBadge />}
</article>
