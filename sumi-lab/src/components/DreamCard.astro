---
import TagList from './TagList.astro';
import BookCandidateBadge from './BookCandidateBadge.astro';
interface Props { post: any }
const { post } = Astro.props;
---
<article class="card dream-card">
  <p class="meta">{post.data.date.toLocaleDateString('tr-TR')}</p>
  <h3><a href={`/ruyalar/${post.slug}`}>{post.data.title}</a></h3>
  <p>{post.data.description}</p>
  <TagList items={post.data.symbols} label="Semboller" />
  <TagList items={post.data.themes} label="Temalar" />
  {post.data.book_candidate && <BookCandidateBadge />}
</article>
